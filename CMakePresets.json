{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug (Unix Makefiles)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/cmake-build-${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MCC_BUILD_STATIC_EXE": "OFF",
        "MCC_CONFIG_BCHECK": "ON",
        "MCC_CONFIG_BACKTRACE": "ON",
        "MCC_BUILD_STRIP": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release (static, stripped, no bcheck/backtrace)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MCC_BUILD_STATIC_EXE": "ON",
        "MCC_BUILD_STRIP": "ON",
        "MCC_CONFIG_BCHECK": "OFF",
        "MCC_CONFIG_BACKTRACE": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "Sanitizer build (mcc_s)",
      "inherits": "debug",
      "cacheVariables": { "MCC_BUILD_SANITIZE": "ON" }
    },
    {
      "name": "diagnostics",
      "displayName": "Everything-on diagnostics (warnings + debug + mcc_s/mcc_p/mcc_c)",
      "inherits": "debug",
      "cacheVariables": { "MCC_DIAGNOSTICS": "ON" }
    },
    {
      "name": "cross",
      "displayName": "Native + all cross compilers",
      "inherits": "debug",
      "cacheVariables": { "MCC_ENABLE_CROSS": "ON" }
    },
    {
      "name": "matrix",
      "displayName": "Toolchain x target matrix (gcc;clang x native;cross)",
      "inherits": "debug",
      "cacheVariables": {
        "MCC_TOOLCHAIN_PROFILE": "gcc;clang",
        "MCC_TARGETS": "native;cross"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "diagnostics", "configurePreset": "diagnostics" },
    { "name": "cross", "configurePreset": "cross" },
    { "name": "matrix", "configurePreset": "matrix" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    { "name": "release", "configurePreset": "release", "output": { "outputOnFailure": true } },
    { "name": "diagnostics", "configurePreset": "diagnostics", "output": { "outputOnFailure": true } }
  ]
}
