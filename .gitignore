# Editor / OS noise
*~
\#*
.#*
.idea
.gdb_history

# CMake build trees (this project builds out-of-source). The CMakePresets.json
# presets use /build (default) and /build-release, /build-asan, /build-cross,
# /build-matrix -- ignore the whole /build-* family.
/build/
/build-*/
/cmake-build-*/
CMakeUserPresets.json

# Stray in-tree compile/link artifacts. CMake builds out-of-source, so the
# former in-tree generated files -- config.h, tccdefs_.h (*_.h), config.mak,
# conftest*/c2str host tool, the tcc/-tcc binaries -- now live in the build
# dir, not here, and no longer need ignoring.
*.o
*.a
*.so
*.exe
*.dll
*.dylib
*.obj
*.pdb
*.lib
*.exp
a.out
gmon.out
*.gcda
*.gcno
tags
TAGS

# win32 native bootstrap (win32/build-tcc.bat) copies these into the tree
win32/doc
win32/examples/libtcc_test.c
win32/libtcc
win32/lib/32
win32/lib/64
win32/include/float.h
win32/include/stdalign.h
win32/include/stdarg.h
win32/include/stdbool.h
win32/include/stddef.h
win32/include/stdnoreturn.h
win32/include/varargs.h
win32/include/tcclib.h
win32/include/tccdefs.h
win32/include/stdatomic.h
win32/include/tgmath.h
